{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Nordic Financial News",
  "colors": {
    "primary": "#1E3A5F",
    "light": "#4A90D9",
    "dark": "#0F2440"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["bash", "python", "ruby", "javascript"],
      "defaults": "all",
      "autogenerate": true
    },
    "mdx": {
      "server": "https://nordicfinancialnews.com",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/pagination",
              "guides/caching",
              "guides/real-time-updates",
              "guides/field-projection",
              "guides/errors"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "openapi.yaml",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Articles",
            "pages": [
              "GET /api/v1/articles",
              "GET /api/v1/articles/{public_id}"
            ]
          },
          {
            "group": "Stories",
            "pages": [
              "GET /api/v1/stories",
              "GET /api/v1/stories/{public_id}",
              "GET /api/v1/stories/{public_id}/articles"
            ]
          },
          {
            "group": "Companies",
            "pages": [
              "GET /api/v1/companies",
              "GET /api/v1/companies/{identifier}",
              "GET /api/v1/companies/{identifier}/articles",
              "GET /api/v1/companies/{identifier}/stories"
            ]
          },
          {
            "group": "Categories",
            "pages": [
              "GET /api/v1/categories",
              "GET /api/v1/categories/{id}",
              "GET /api/v1/categories/{public_id}/articles",
              "GET /api/v1/categories/{public_id}/stories"
            ]
          },
          {
            "group": "Countries",
            "pages": [
              "GET /api/v1/countries",
              "GET /api/v1/countries/{identifier}",
              "GET /api/v1/countries/{identifier}/articles",
              "GET /api/v1/countries/{identifier}/stories",
              "GET /api/v1/countries/{identifier}/exchanges"
            ]
          },
          {
            "group": "Exchanges",
            "pages": [
              "GET /api/v1/exchanges",
              "GET /api/v1/exchanges/{identifier}",
              "GET /api/v1/exchanges/{identifier}/companies"
            ]
          },
          {
            "group": "Search",
            "pages": [
              "GET /api/v1/search"
            ]
          },
          {
            "group": "Utility",
            "pages": [
              "GET /api/v1/meta",
              "GET /api/v1/health"
            ]
          }
        ]
      },
      {
        "tab": "MCP server",
        "groups": [
          {
            "group": "MCP server",
            "pages": [
              "mcp/index",
              "mcp/tools",
              "mcp/resources"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:api@nordicfinancialnews.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://nordicfinancialnews.com/account/api_keys/new"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/nordicfinnews",
      "github": "https://github.com/nordicfinancialnews"
    }
  },
  "search": {
    "prompt": "Search docs..."
  }
}
