{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Nordic Financial News",
  "colors": {
    "primary": "#01B2FF",
    "light": "#01B2FF",
    "dark": "#0090D0"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#F9FAFB",
      "dark": "#0a0a0b"
    }
  },
  "styling": {
    "codeblocks": "dark"
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["bash", "python", "ruby", "javascript"],
      "defaults": "all",
      "autogenerate": true
    },
    "mdx": {
      "server": "https://nordicfinancialnews.com",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "getting-started",
              "ai-tools",
              "support"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/pagination",
              "guides/caching",
              "guides/real-time-updates",
              "guides/field-projection",
              "guides/errors"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "https://nordicfinancialnews.com/swagger/v1/swagger.yaml",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Articles",
            "pages": [
              "GET /api/v1/articles",
              "GET /api/v1/articles/{id}"
            ]
          },
          {
            "group": "Stories",
            "pages": [
              "GET /api/v1/stories",
              "GET /api/v1/stories/{id}"
            ]
          },
          {
            "group": "Companies",
            "pages": [
              "GET /api/v1/companies",
              "GET /api/v1/companies/{identifier}",
              "GET /api/v1/companies/{identifier}/articles",
              "GET /api/v1/companies/{identifier}/stories"
            ]
          },
          {
            "group": "Categories",
            "pages": [
              "GET /api/v1/categories"
            ]
          },
          {
            "group": "Countries",
            "pages": [
              "GET /api/v1/countries",
              "GET /api/v1/countries/{identifier}"
            ]
          },
          {
            "group": "Exchanges",
            "pages": [
              "GET /api/v1/exchanges",
              "GET /api/v1/exchanges/{identifier}",
              "GET /api/v1/exchanges/{identifier}/companies"
            ]
          },
          {
            "group": "Indices",
            "pages": [
              "GET /api/v1/indices",
              "GET /api/v1/indices/{identifier}",
              "GET /api/v1/indices/{identifier}/companies"
            ]
          },
          {
            "group": "Watchlists",
            "pages": [
              "GET /api/v1/watchlists",
              "GET /api/v1/watchlists/{id}",
              "GET /api/v1/watchlists/{watchlist_id}/companies"
            ]
          },
          {
            "group": "Search",
            "pages": [
              "GET /api/v1/search"
            ]
          },
          {
            "group": "Utility",
            "pages": [
              "GET /api/v1/meta",
              "GET /api/v1/health"
            ]
          }
        ]
      },
      {
        "tab": "Model Context Protocol (MCP)",
        "groups": [
          {
            "group": "Model Context Protocol (MCP)",
            "pages": [
              "model-context-protocol/index",
              "model-context-protocol/tools",
              "model-context-protocol/resources"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Get API key",
      "href": "https://nordicfinancialnews.com/settings/api_keys"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode",
      "mcp"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/nordicfinnews",
      "github": "https://github.com/nordicfinancialnews"
    }
  },
  "search": {
    "prompt": "Search docs..."
  }
}
